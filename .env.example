# ============================================================
# پیکربندی محیط — نمونه. این فایل را به .env کپی کنید.
# ============================================================

NODE_ENV=development

# ---------- Database ----------
POSTGRES_USER=saman
POSTGRES_PASSWORD=saman_secret
POSTGRES_DB=saman
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://saman:saman_secret@localhost:5432/saman?schema=public

# ---------- API ----------
API_PORT=4000
API_PREFIX=api
API_VERSION=v1
CORS_ORIGIN=http://localhost:3000

# ---------- JWT / Auth ----------
JWT_ACCESS_SECRET=change_me_access_secret_please_use_64_chars_minimum
JWT_ACCESS_TTL=900            # 15 دقیقه (ثانیه)
JWT_REFRESH_SECRET=change_me_refresh_secret_please_use_64_chars_minimum
JWT_REFRESH_TTL=2592000       # 30 روز (ثانیه)
BCRYPT_ROUNDS=12

# ---------- OTP / SMS (کاوه‌نگار) ----------
SMS_PROVIDER=mock             # mock | kavenegar
KAVENEGAR_API_KEY=
SMS_SENDER=10004346
OTP_TTL=120                   # اعتبار کد یکبارمصرف (ثانیه)
OTP_LENGTH=5

# ---------- Payment Gateway (زرین‌پال) ----------
PAYMENT_PROVIDER=mock         # mock | zarinpal
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
PAYMENT_CALLBACK_URL=http://localhost:4000/api/v1/payments/verify

# ---------- File Storage (S3 / MinIO) ----------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=saman-files
S3_PUBLIC_URL=http://localhost:9000/saman-files
MAX_UPLOAD_MB=10

# ---------- Rate limiting ----------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME=سامان
